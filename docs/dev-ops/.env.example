# docker-compose-app.yml 读取的环境变量样例。
# 复制为 .env 并填入真实值后，与 docker-compose-app.yml 放在同一目录执行：
#   docker-compose -f docker-compose-app.yml up -d
# 注意：.env 含密钥，切勿提交到 git（已在 .gitignore 中忽略）。

# ===== 必填：缺失会导致 prod 应用启动失败（占位无法解析）=====
# 大模型 API 鉴权密钥
AI_API_KEY=sk-replace-me
# 百度 AI 搜索 MCP 的 api_key
BAIDU_SEARCH_API_KEY=bce-v3/replace-me
# 百度地图 MCP 的 ak
BAIDU_MAP_AK=replace-me

# ===== 选填：不设置则使用 prod-agent.yml 中的默认值 =====
AI_API_BASE_URL=https://apis.itedus.cn
AI_API_COMPLETIONS_PATH=v1/chat/completions
AI_API_EMBEDDINGS_PATH=v1/embeddings
AI_CHAT_MODEL=gpt-4.1